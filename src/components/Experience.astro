---
import SectionHeading from "./SectionHeading.astro";
import { experience } from "../data/resume";
---

<section id="experience" class="mt-16 scroll-mt-8">
  <SectionHeading eyebrow="Career" title="Experience" />

  <div class="space-y-5">
    {
      experience.map((item) => (
        <article class="glass-card glass-card-hover p-6 sm:p-8">
          <div class="flex flex-wrap items-baseline justify-between gap-2">
            <h3 class="text-lg font-bold sm:text-xl">{item.role}</h3>
            <span class="text-sm font-medium text-muted">{item.period}</span>
          </div>
          <p class="mt-1 text-base font-semibold text-gradient">
            {item.organization}
          </p>
          <p class="text-sm text-muted">{item.location}</p>

          <ul class="mt-4 space-y-2">
            {item.highlights.map((h) => (
              <li class="flex gap-3 text-sm leading-relaxed text-muted">
                <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-[color:var(--color-accent)]" />
                <span>{h}</span>
              </li>
            ))}
          </ul>
        </article>
      ))
    }
  </div>
</section>
