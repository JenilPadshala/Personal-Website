---
import { profile } from "../data/resume";
---

<section id="about" class="scroll-mt-8">
  <div class="glass-card sheen animate-rise p-8 sm:p-12">
    <p class="text-sm font-medium text-muted">Hi, I'm</p>
    <h1 class="mt-2 text-4xl font-extrabold tracking-tight sm:text-6xl">
      {profile.name}
    </h1>
    <p class="mt-3 text-xl font-semibold text-gradient sm:text-2xl">
      {profile.tagline}
    </p>
    <p class="mt-6 max-w-2xl text-base leading-relaxed text-muted sm:text-lg">
      {profile.summary}
    </p>

    <div class="mt-8 flex flex-wrap items-center gap-3">
      <a
        href={profile.resumeUrl}
        download
        class="glass sheen inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-semibold transition hover:-translate-y-0.5"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
          <path d="M12 3a1 1 0 0 1 1 1v9.59l2.3-2.3a1 1 0 0 1 1.4 1.42l-4 4a1 1 0 0 1-1.4 0l-4-4a1 1 0 1 1 1.4-1.42l2.3 2.3V4a1 1 0 0 1 1-1ZM5 19a1 1 0 0 1 1-1h12a1 1 0 1 1 0 2H6a1 1 0 0 1-1-1Z" />
        </svg>
        Download Resume
      </a>
      {
        profile.socials.map((s) => (
          <a
            href={s.href}
            target={s.href.startsWith("http") ? "_blank" : undefined}
            rel="noopener noreferrer"
            class="rounded-full px-4 py-2.5 text-sm font-medium text-muted transition hover:text-[color:var(--text-strong)]"
          >
            {s.label}
          </a>
        ))
      }
    </div>
  </div>
</section>
