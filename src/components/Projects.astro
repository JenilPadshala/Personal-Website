---
import SectionHeading from "./SectionHeading.astro";
import { projects } from "../data/resume";
---

<section id="projects" class="mt-16 scroll-mt-8">
  <SectionHeading eyebrow="Selected Work" title="Projects" />

  <div class="grid gap-5 sm:grid-cols-2">
    {
      projects.map((project) => (
        <article class="glass-card glass-card-hover flex flex-col p-6 sm:p-7">
          <div class="flex flex-wrap items-baseline justify-between gap-2">
            <h3 class="text-lg font-bold">{project.name}</h3>
            <span class="text-xs font-medium text-muted">{project.period}</span>
          </div>

          <div class="mt-3 flex flex-wrap gap-1.5">
            {project.stack.map((tech) => (
              <span class="rounded-full border border-[color:var(--glass-border)] bg-[color:var(--glass-bg)] px-2.5 py-1 text-[0.7rem] font-medium text-muted">
                {tech}
              </span>
            ))}
          </div>

          <ul class="mt-4 space-y-2">
            {project.highlights.map((h) => (
              <li class="flex gap-2.5 text-sm leading-relaxed text-muted">
                <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-[color:var(--color-accent-2)]" />
                <span>{h}</span>
              </li>
            ))}
          </ul>

          {project.link && (
            <a
              href={project.link}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-5 inline-flex items-center gap-1 text-sm font-semibold text-gradient"
            >
              View project →
            </a>
          )}
        </article>
      ))
    }
  </div>
</section>
