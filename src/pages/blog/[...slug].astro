---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

export const getStaticPaths = (async () => {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content } = await render(post);

const dateFmt = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={`${post.data.title} — Jenil Padshala`} description={post.data.description}>
  <article class="animate-rise">
    <a
      href="/blog"
      class="mb-6 inline-flex items-center gap-1 text-sm font-medium text-muted transition hover:text-[color:var(--text-strong)]"
    >
      ← Back to blog
    </a>

    <header class="glass-card sheen mb-8 p-8 sm:p-10">
      <div class="flex flex-wrap gap-1.5">
        {
          post.data.tags.map((tag) => (
            <span class="rounded-full border border-[color:var(--glass-border)] px-2.5 py-1 text-[0.7rem] font-medium text-muted">
              {tag}
            </span>
          ))
        }
      </div>
      <h1 class="mt-4 text-3xl font-extrabold tracking-tight sm:text-4xl">
        {post.data.title}
      </h1>
      <time
        datetime={post.data.date.toISOString()}
        class="mt-3 block text-sm text-muted"
      >
        {dateFmt.format(post.data.date)}
      </time>
    </header>

    <div class="glass-card p-7 sm:p-10">
      <div class="prose-glass">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>

<style is:global>
  .prose-glass {
    color: var(--text-muted);
    line-height: 1.75;
    font-size: 1rem;
  }
  .prose-glass > * + * {
    margin-top: 1.15rem;
  }
  .prose-glass h2 {
    color: var(--text-strong);
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 2.25rem;
    margin-bottom: 0.5rem;
  }
  .prose-glass h3 {
    color: var(--text-strong);
    font-size: 1.2rem;
    font-weight: 700;
    margin-top: 1.75rem;
  }
  .prose-glass a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose-glass strong {
    color: var(--text-strong);
    font-weight: 600;
  }
  .prose-glass ul,
  .prose-glass ol {
    padding-left: 1.4rem;
  }
  .prose-glass ul {
    list-style: disc;
  }
  .prose-glass ol {
    list-style: decimal;
  }
  .prose-glass li + li {
    margin-top: 0.4rem;
  }
  .prose-glass code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.85em;
    background: color-mix(in srgb, var(--color-accent) 14%, transparent);
    padding: 0.15em 0.4em;
    border-radius: 0.4rem;
    color: var(--text-strong);
  }
  .prose-glass pre {
    background: rgba(0, 0, 0, 0.35);
    border: 1px solid var(--glass-border);
    border-radius: 1rem;
    padding: 1.1rem 1.25rem;
    overflow-x: auto;
  }
  .prose-glass pre code {
    background: none;
    padding: 0;
    color: inherit;
    font-size: 0.85rem;
  }
  .prose-glass blockquote {
    border-left: 3px solid var(--color-accent);
    padding-left: 1rem;
    font-style: italic;
  }
</style>
